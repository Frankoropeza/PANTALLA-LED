---
/**
 * index.astro — Página de inicio de PantallaLED
 * Orquestador limpio: importa secciones, define schemas JSON-LD
 */

import Base from '../layouts/Base.astro'
import CtaBar from '../components/CtaBar.astro'
import HeroIndex from '../components/sections/HeroIndex.astro'
import CategoriasIndex from '../components/sections/CategoriasIndex.astro'
import TrustIndex from '../components/sections/TrustIndex.astro'
import ServiciosIndex from '../components/sections/ServiciosIndex.astro'
import EspecificacionesIndex from '../components/sections/EspecificacionesIndex.astro'
import ProcesoIndex from '../components/sections/ProcesoIndex.astro'
import ReviewsIndex from '../components/sections/ReviewsIndex.astro'
import FaqCotizacionIndex from '../components/sections/FaqCotizacionIndex.astro'
import CTAFinalIndex from '../components/sections/CTAFinalIndex.astro'

import { SITE, CONTACT } from '../config/site'

// ─── JSON-LD: LocalBusiness ───────────────────────────────────────────────────
const schemaLocalBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  telephone: CONTACT.phone,
  email: CONTACT.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Ciudad de México',
    addressRegion: 'CDMX',
    addressCountry: 'MX',
  },
  areaServed: {
    '@type': 'Country',
    name: 'México',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday'],
      opens: '09:00',
      closes: '14:00',
    },
  ],
  priceRange: '$$',
  currenciesAccepted: 'MXN',
  paymentAccepted: 'Efectivo, Transferencia, Tarjeta',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Pantallas LED México',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Product', name: 'Pantallas LED Exteriores' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Product', name: 'Pantallas LED Interiores' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Renta de Pantallas LED' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Instalación de Pantallas LED' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Mantenimiento de Pantallas LED' } },
    ],
  },
  sameAs: [],
}

// ─── JSON-LD: FAQPage ─────────────────────────────────────────────────────────
const schemaFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta una pantalla LED en México?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El precio depende del tamaño, paso de pixel y tipo (interior/exterior). Una pantalla exterior de 2m × 3m con P6 parte desde $25,000 MXN. Las interiores Ultra HD con P2 pueden superar $80,000 MXN para proyectos de mayor formato. Contáctanos para cotización exacta según tu proyecto.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué paso de pixel necesito para mi pantalla?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Depende de la distancia de visión. Para distancias de 3-6 metros usamos P2 o P3 (interior). Para 5-10 metros en exteriores, P4 o P5. Para espectaculares en calles principales, P6 a P10. En eventos, P3.9 o P4.8 son los estándares.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto tiempo tarda la instalación?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Una pantalla interior de tamaño estándar se instala en 1-2 días. Un espectacular exterior de 10m² toma de 2 a 4 días incluyendo estructura. Proyectos mayores o en estadios pueden tomar 1-3 semanas.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Las pantallas incluyen garantía?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Todos nuestros equipos tienen garantía de fábrica de 2 años que cubre defectos de manufactura, módulos LED, tarjetas de recepción y fuentes de poder. El servicio de garantía se brinda en sitio, sin costos de traslado adicionales en CDMX y área metropolitana.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Hacen instalaciones en toda la República?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Contamos con operación propia en CDMX y Estado de México, y cobertura comercial en toda la República Mexicana. Coordinamos instalaciones en Guadalajara, Monterrey, Puebla, Cancún y otras ciudades con aliados técnicos certificados.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Rentan pantallas para eventos de un día?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Ofrecemos renta de módulos LED por día, fin de semana o semana completa. El servicio incluye transporte, armado, operador durante el evento y desarmado. Ideal para conciertos, convenciones, bodas y activaciones de marca.',
      },
    },
  ],
}

// ─── JSON-LD: WebSite ─────────────────────────────────────────────────────────
const schemaWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  inLanguage: 'es-MX',
  publisher: {
    '@id': `${SITE.url}/#organization`,
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE.url}/buscar?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
}

// ─── JSON-LD: BreadcrumbList ──────────────────────────────────────────────────
const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: SITE.url,
    },
  ],
}

// ─── Meta SEO ─────────────────────────────────────────────────────────────────
const title = `Pantallas LED en México | Venta, Renta e Instalación — ${SITE.name}`
const description = 'Especialistas en pantallas LED de alta resolución para exteriores e interiores. Venta, renta e instalación certificada en toda la República Mexicana. Cotización gratis en 2 horas.'
const canonical = SITE.url
---

<Base {title} {description} {canonical}>

  <!-- ─── Secciones ────────────────────────────────────────────────────── -->
  <HeroIndex />
  <CtaBar />
  <CategoriasIndex />
  <TrustIndex />
  <ServiciosIndex />
  <EspecificacionesIndex />
  <ProcesoIndex />
  <ReviewsIndex />
  <FaqCotizacionIndex />
  <CTAFinalIndex />

  <!-- ─── JSON-LD Schemas ──────────────────────────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebSite)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />

</Base>
