---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { url } from '../utils/url';

const productos = await getCollection('productos');
---

<Layout
  title="Productos"
  description="Catálogo de pantallas LED para exterior e interior. Encuentra el modelo ideal para tu proyecto."
>
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="section-title text-5xl">Catálogo de Productos</h1>
      <p class="section-subtitle max-w-2xl mx-auto">
        Pantallas LED de alta resolución para cada necesidad. Exteriores, interiores y formatos especiales.
      </p>
    </div>
  </section>

  <!-- Filtros -->
  <section class="py-6 bg-gray-950 border-b border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-wrap gap-3">
      <span class="text-gray-400 text-sm self-center mr-2">Filtrar:</span>
      {['Todos', 'Exterior', 'Interior', 'Flexible'].map((f) => (
        <button class="px-4 py-1.5 rounded-full text-sm font-medium border border-gray-700 text-gray-300 hover:border-primary hover:text-primary transition-colors">
          {f}
        </button>
      ))}
    </div>
  </section>

  <!-- Productos Grid -->
  <section class="py-16 bg-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {productos.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {productos.map((p) => (
            <a href={`/productos/${p.slug}`} class="card group">
              <div class="aspect-video bg-gray-800 rounded-lg mb-4 flex items-center justify-center overflow-hidden">
                {p.data.image ? (
                  <img src={p.data.image} alt={p.data.title} class="w-full h-full object-cover" />
                ) : (
                  <span class="text-gray-600 text-sm">Imagen próximamente</span>
                )}
              </div>
              <div class="flex items-center gap-2 mb-2">
                <span class="bg-primary/10 text-primary text-xs font-medium px-2 py-0.5 rounded-full">
                  {p.data.tipo}
                </span>
              </div>
              <h3 class="text-white font-semibold text-xl mb-2 group-hover:text-primary transition-colors">
                {p.data.title}
              </h3>
              <p class="text-gray-400 text-sm mb-3">{p.data.description}</p>
              <p class="text-gray-500 text-xs">Paso de pixel: {p.data.pixelPitch}</p>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 text-gray-500">
          <p class="text-lg">Catálogo en construcción. ¡Próximamente!</p>
          <a href={url('/contacto')} class="btn-primary inline-flex mt-6">Contactar para más información</a>
        </div>
      )}
    </div>
  </section>
</Layout>
