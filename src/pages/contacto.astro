---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto"
  description="Contáctanos para obtener una cotización personalizada de pantallas LED para tu negocio."
>
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="section-title text-5xl">Contáctanos</h1>
      <p class="section-subtitle max-w-xl mx-auto">
        Cuéntanos sobre tu proyecto y te enviaremos una cotización personalizada sin costo ni compromiso.
      </p>
    </div>
  </section>

  <!-- Contacto Grid -->
  <section class="py-16 bg-gray-950">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Formulario -->
        <div class="lg:col-span-3 card">
          <h2 class="text-xl font-semibold text-white mb-6">Envíanos un mensaje</h2>
          <form class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Nombre *</label>
                <input
                  type="text"
                  name="nombre"
                  required
                  placeholder="Tu nombre completo"
                  class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors placeholder:text-gray-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Empresa</label>
                <input
                  type="text"
                  name="empresa"
                  placeholder="Nombre de tu empresa"
                  class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors placeholder:text-gray-500"
                />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Email *</label>
                <input
                  type="email"
                  name="email"
                  required
                  placeholder="correo@empresa.com"
                  class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors placeholder:text-gray-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Teléfono</label>
                <input
                  type="tel"
                  name="telefono"
                  placeholder="+52 55 0000 0000"
                  class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors placeholder:text-gray-500"
                />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">Tipo de proyecto</label>
              <select
                name="tipo"
                class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors"
              >
                <option value="">Selecciona una opción</option>
                <option value="compra">Compra de pantalla</option>
                <option value="renta">Renta para evento</option>
                <option value="mantenimiento">Mantenimiento</option>
                <option value="asesoria">Asesoría técnica</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">Mensaje *</label>
              <textarea
                name="mensaje"
                required
                rows="4"
                placeholder="Describe tu proyecto: dimensiones aproximadas, ubicación, presupuesto..."
                class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors placeholder:text-gray-500 resize-none"
              ></textarea>
            </div>
            <button type="submit" class="btn-primary w-full text-base">
              Enviar Mensaje
            </button>
          </form>
        </div>

        <!-- Info de contacto -->
        <div class="lg:col-span-2 space-y-6">
          <div class="card">
            <h3 class="text-white font-semibold mb-4">Información de Contacto</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-300">Teléfono / WhatsApp</p>
                  <a href="tel:+525500000000" class="text-primary hover:text-primary-light text-sm">+52 55 0000 0000</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-300">Email</p>
                  <a href="mailto:contacto@pantalla-led.com.mx" class="text-primary hover:text-primary-light text-sm">contacto@pantalla-led.com.mx</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-300">Ubicación</p>
                  <p class="text-gray-400 text-sm">Ciudad de México, México<br/>Cobertura nacional</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="card bg-primary/10 border-primary/30">
            <h3 class="text-white font-semibold mb-2">Horario de Atención</h3>
            <p class="text-gray-400 text-sm">Lunes a Viernes: 9:00 - 18:00</p>
            <p class="text-gray-400 text-sm">Sábado: 9:00 - 14:00</p>
            <p class="text-primary text-sm font-medium mt-2">Soporte técnico 24/7</p>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
