---
import '../styles/global.css'
import TopBar       from '../components/global/TopBar.astro'
import Header       from '../components/global/Header.astro'
import Footer       from '../components/global/Footer.astro'
import WhatsAppButton from '../components/global/WhatsAppButton.astro'
import { url } from '../utils/url'

interface Props {
  title: string
  description: string
  canonical?: string
  ogImage?: string
}

const { title, description, canonical, ogImage } = Astro.props
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="dark" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="PantallaLED" />
  <meta property="og:locale"      content="es_MX" />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <meta name="robots" content="index, follow" />
  <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
  <link rel="apple-touch-icon"     href={url('/apple-touch-icon.png')} />

  <!-- Google Fonts — Outfit (mismo que PROYECTORED para coherencia de sistema) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <TopBar />
  <Header />
  <main>
    <!--
      REGLA DE LAYOUT — válida para todas las páginas:
      Orden obligatorio: Hero → CtaBar → resto de secciones.
      No insertar bloques entre Hero y CtaBar.
    -->
    <slot />
  </main>
  <Footer />
  <WhatsAppButton />
</body>
</html>

<style is:global>
  :root {
    color-scheme: dark;

    /* Colores primarios — fuente de verdad */
    --c-primary:       #0066CC;
    --c-primary-dark:  #004499;
    --c-primary-light: rgba(0, 102, 204, 0.12);
    --c-primary-rgb:   0, 102, 204;

    /* Backgrounds */
    --c-bg:      #080C18;
    --c-bg-2:    #0F1629;
    --c-surface: #141D35;
    --c-surface-2: #1A2540;

    /* Bordes */
    --c-border:   #1E2D50;
    --c-border-2: #253560;

    /* Tipografía */
    --c-ink:   #F0F4FF;
    --c-ink-2: #C5D0E6;
    --c-muted: #7A8CAB;
    --c-white: #FFFFFF;

    /* Fuentes */
    --font-sans:    'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;

    /* Stack de navegación */
    --topbar-height: 36px;
    --header-height: 80px;
    --stack-height:  116px;

    /* Sombras */
    --shadow-sm:  0 1px 4px rgba(0,0,0,0.5);
    --shadow-md:  0 4px 12px rgba(0,0,0,0.5);
    --shadow-lg:  0 8px 24px rgba(0,0,0,0.6);
    --shadow-glow: 0 0 24px rgba(0,102,204,0.25);

    /* Layout */
    --max-w:        1400px;
    --container-px: 1.5rem;
    --section-py:   clamp(4rem, 7vw, 6rem);
    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-full: 9999px;
  }

  *, *::before, *::after {
    margin: 0; padding: 0;
    box-sizing: border-box;
  }

  html, body { overflow-x: hidden; }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family: var(--font-sans);
    color: var(--c-ink-2);
    background: var(--c-bg);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img { max-width: 100%; height: auto; display: block; }
  a   { color: inherit; text-decoration: none; }
  ul, ol { list-style: none; }
  button { font: inherit; cursor: pointer; border: none; background: none; }

  .container {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: var(--container-px);
  }

  /* Botones globales */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--c-primary);
    color: #fff;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.9375rem;
    font-family: var(--font-sans);
    transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(0,102,204,.35);
  }
  .btn-primary:hover {
    background: var(--c-primary-dark);
    color: #fff;
    box-shadow: 0 6px 20px rgba(0,102,204,.45);
    transform: translateY(-1px);
  }
  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 2px solid rgba(255,255,255,0.25);
    color: #fff;
    padding: 0.8125rem 1.75rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.9375rem;
    font-family: var(--font-sans);
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-secondary:hover {
    border-color: rgba(255,255,255,0.6);
    background: rgba(255,255,255,0.06);
    color: #fff;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 2px solid var(--c-primary);
    color: var(--c-primary);
    padding: 0.8125rem 1.75rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.9375rem;
    font-family: var(--font-sans);
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s;
  }
  .btn-outline:hover { background: var(--c-primary); color: #fff; }

  :focus-visible {
    outline: 2px solid var(--c-primary);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  @media (max-width: 640px) {
    :root {
      --topbar-height: 32px;
      --stack-height: calc(32px + var(--header-height));
    }
  }
</style>
