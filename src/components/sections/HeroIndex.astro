---
// HeroIndex.astro — Hero principal del sitio
// H1 con keyword principal, badge, métricas inline

import { waUrl, WA_MESSAGES } from '../../config/site'
import { url } from '../../utils/url'
---

<section class="hero" aria-labelledby="hero-heading">

  <!-- Fondo: grid pattern + glow central -->
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__grid-pattern"></div>
    <div class="hero__glow hero__glow--center"></div>
    <div class="hero__glow hero__glow--left"></div>
  </div>

  <div class="container hero__inner">

    <!-- Badge -->
    <p class="hero__badge">
      <span class="hero__badge-dot" aria-hidden="true"></span>
      Pantallas LED de Alta Resolución — Tecnología SMD y COB
    </p>

    <!-- H1 -->
    <h1 id="hero-heading" class="hero__title">
      Pantallas LED para tu<br/>
      <span class="hero__title-accent">Negocio o Evento</span>
    </h1>

    <!-- Subtítulo -->
    <p class="hero__desc">
      Venta, renta e instalación de pantallas LED de alta resolución en toda la República Mexicana.
      Exteriores, interiores, eventos y publicidad. Cotización gratuita el mismo día.
    </p>

    <!-- CTAs -->
    <div class="hero__ctas">
      <a href={url('/productos/')} class="btn-primary hero__btn-primary">
        Ver catálogo LED
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href={waUrl(WA_MESSAGES.cotizacion)}
        class="hero__btn-wa"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Cotizar por WhatsApp
      </a>
    </div>

    <!-- Trust signals -->
    <div class="hero__trust">
      <span class="hero__trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Garantía 2 años
      </span>
      <span class="hero__trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Entrega en todo México
      </span>
      <span class="hero__trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Instalación certificada
      </span>
      <span class="hero__trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Soporte 24/7
      </span>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--c-bg);
    padding-block: clamp(5rem, 10vw, 8rem);
  }

  /* ─── Fondo ─── */
  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__grid-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image:
      linear-gradient(rgba(0,102,204,0.8) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,102,204,0.8) 1px, transparent 1px);
    background-size: 64px 64px;
  }

  .hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .hero__glow--center {
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(0,102,204,0.2) 0%, transparent 70%);
  }

  .hero__glow--left {
    top: 60%;
    left: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(0,102,204,0.1) 0%, transparent 70%);
  }

  /* ─── Inner ─── */
  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.75rem;
  }

  /* ─── Badge ─── */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0,102,204,0.1);
    border: 1px solid rgba(0,102,204,0.3);
    color: rgba(150,190,255,0.9);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.375rem 1rem;
    border-radius: 100px;
    letter-spacing: 0.02em;
  }

  .hero__badge-dot {
    display: block;
    width: 8px;
    height: 8px;
    background: var(--c-primary);
    border-radius: 50%;
    animation: hero-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes hero-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.85); }
  }

  /* ─── H1 ─── */
  .hero__title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    color: var(--c-ink);
    line-height: 1.08;
    letter-spacing: -0.03em;
    max-width: 800px;
  }

  .hero__title-accent {
    color: var(--c-primary);
    display: inline-block;
  }

  /* ─── Desc ─── */
  .hero__desc {
    font-size: clamp(1rem, 1.5vw, 1.175rem);
    color: var(--c-muted);
    line-height: 1.7;
    max-width: 600px;
  }

  /* ─── CTAs ─── */
  .hero__ctas {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--c-primary);
    color: #fff;
    padding: 0.9375rem 2rem;
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0,102,204,0.4);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .hero__btn-primary:hover {
    background: var(--c-primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0,102,204,0.5);
  }
  .hero__btn-primary:active { transform: translateY(0); }

  .hero__btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(37,211,102,0.1);
    border: 1px solid rgba(37,211,102,0.3);
    color: rgba(37,211,102,0.95);
    padding: 0.9375rem 2rem;
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
  }
  .hero__btn-wa:hover {
    background: rgba(37,211,102,0.18);
    border-color: rgba(37,211,102,0.55);
    color: #25D366;
    transform: translateY(-1px);
  }

  /* ─── Trust ─── */
  .hero__trust {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .hero__trust-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--c-muted);
    font-weight: 500;
  }

  .hero__trust-item svg { color: var(--c-primary); flex-shrink: 0; }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .hero { min-height: auto; padding-block: 4rem 3rem; }
    .hero__title { font-size: clamp(2rem, 8vw, 2.5rem); }
    .hero__ctas { flex-direction: column; width: 100%; }
    .hero__btn-primary,
    .hero__btn-wa { width: 100%; justify-content: center; }
    .hero__trust { gap: 1rem; }
  }
</style>
