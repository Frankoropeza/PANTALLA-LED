---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import { url } from '../../utils/url';

export async function getStaticPaths() {
  const productos = await getCollection('productos');
  return productos.map((p) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const producto = await getEntry('productos', slug!);

if (!producto) return Astro.redirect('/productos');

const { Content } = await producto.render();
---

<Layout title={producto.data.title} description={producto.data.description}>
  <section class="pt-32 pb-16 bg-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href={url('/')} class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <a href={url('/productos')} class="hover:text-white transition-colors">Productos</a>
        <span>/</span>
        <span class="text-gray-300">{producto.data.title}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
        <!-- Imagen -->
        <div class="aspect-video bg-gray-900 border border-gray-800 rounded-2xl flex items-center justify-center">
          {producto.data.image ? (
            <img src={producto.data.image} alt={producto.data.title} class="w-full h-full object-cover rounded-2xl" />
          ) : (
            <span class="text-gray-600 text-sm">Imagen próximamente</span>
          )}
        </div>

        <!-- Info -->
        <div>
          <span class="inline-block bg-primary/10 text-primary text-xs font-medium px-3 py-1 rounded-full mb-4">
            {producto.data.tipo}
          </span>
          <h1 class="text-4xl font-heading font-bold text-white mb-4">{producto.data.title}</h1>
          <p class="text-gray-400 leading-relaxed mb-6">{producto.data.description}</p>

          <dl class="space-y-3 mb-8">
            <div class="flex gap-3">
              <dt class="text-gray-500 w-32 flex-shrink-0 text-sm">Pixel Pitch:</dt>
              <dd class="text-white text-sm font-medium">{producto.data.pixelPitch}</dd>
            </div>
            {producto.data.luminosidad && (
              <div class="flex gap-3">
                <dt class="text-gray-500 w-32 flex-shrink-0 text-sm">Luminosidad:</dt>
                <dd class="text-white text-sm font-medium">{producto.data.luminosidad}</dd>
              </div>
            )}
            {producto.data.resolucion && (
              <div class="flex gap-3">
                <dt class="text-gray-500 w-32 flex-shrink-0 text-sm">Resolución:</dt>
                <dd class="text-white text-sm font-medium">{producto.data.resolucion}</dd>
              </div>
            )}
          </dl>

          <a href={url('/contacto')} class="btn-primary inline-flex">Solicitar Cotización</a>
        </div>
      </div>

      <!-- Contenido Markdown -->
      <article class="prose prose-invert prose-lg max-w-none
        prose-headings:font-heading prose-headings:text-white
        prose-p:text-gray-400 prose-li:text-gray-400
        prose-a:text-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-white">
        <Content />
      </article>

    </div>
  </section>
</Layout>
