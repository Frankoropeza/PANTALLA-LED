---
// ReviewsIndex.astro — Testimonios de clientes
// Grid de 6 reseñas verificadas

import SectionHeader from '../ui/SectionHeader.astro'

const reviews = [
  {
    name: 'Carlos Mendoza',
    company: 'Grupo Publicitario CM',
    role: 'Director comercial',
    text: 'Instalamos 4 espectaculares LED en avenidas principales de CDMX. El proceso fue impecable: cotización rápida, instalación en tiempo y soporte post-venta real. Las pantallas llevan 18 meses sin un solo problema.',
    rating: 5,
  },
  {
    name: 'Sofía Ramírez',
    company: 'Centro Comercial Plaza Norte',
    role: 'Gerente de marketing',
    text: 'Necesitábamos una pantalla interior para el patio central. Nos asesoraron sobre el paso de pixel correcto, instalaron sin interrumpir operaciones y el resultado visual es impresionante. El colores y brillo son perfectos.',
    rating: 5,
  },
  {
    name: 'Luis Herrera',
    company: 'Eventos LH',
    role: 'Productor de eventos',
    text: 'Rentamos módulos LED para conciertos de 3 días. La entrega fue puntual, el equipo técnico llegó a montar 4 horas antes del evento y el soporte en vivo fue clave. Ya trabaja solo con ellos para todos mis proyectos.',
    rating: 5,
  },
  {
    name: 'Mariana Torres',
    company: 'Restaurante Terrae',
    role: 'Propietaria',
    text: 'Quería una pantalla para el interior del restaurante que se viera premium. Me mostraron opciones, me explicaron las diferencias y eligieron el P2.5 que fue exactamente lo que necesitaba. El servicio fue excelente.',
    rating: 5,
  },
  {
    name: 'Roberto Jiménez',
    company: 'Club Deportivo Águilas',
    role: 'Administrador general',
    text: 'Instalamos un marcador LED en el estadio. El equipo hizo el proyecto desde cero: estructura, pantalla y software. Llevamos 2 años de operación y el mantenimiento preventivo ha sido puntual y eficiente.',
    rating: 5,
  },
  {
    name: 'Ana Guerrero',
    company: 'Universidad Tecnológica',
    role: 'Directora de infraestructura',
    text: 'Instalamos pantallas en 3 auditorios. El proyecto incluyó el diseño, instalación y capacitación al personal técnico. La calidad de imagen supera lo que teníamos instalado anteriormente. Muy recomendables.',
    rating: 5,
  },
]
---

<section class="section section--surface reviews-section" id="testimonios" aria-labelledby="reviews-heading">
  <div class="container">

    <SectionHeader
      eyebrow="Testimonios"
      title="Lo que dicen nuestros <span>clientes</span>"
      desc="Más de 500 proyectos entregados en toda la República Mexicana. Aquí algunos testimonios reales."
    />

    <div class="reviews-grid" role="list">
      {reviews.map((r) => (
        <article class="review-card" role="listitem">
          <!-- Estrellas -->
          <div class="review-card__stars" aria-label={`${r.rating} de 5 estrellas`}>
            {Array.from({ length: r.rating }).map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Texto -->
          <blockquote class="review-card__text">"{r.text}"</blockquote>

          <!-- Autor -->
          <footer class="review-card__author">
            <div class="review-card__avatar" aria-hidden="true">
              {r.name.charAt(0)}
            </div>
            <div class="review-card__author-info">
              <span class="review-card__name">{r.name}</span>
              <span class="review-card__role">{r.role} · {r.company}</span>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <!-- Trust badge -->
    <div class="reviews-footer">
      <div class="reviews-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        <span>Reseñas verificadas de clientes reales. Sin testimonios fabricados.</span>
      </div>
    </div>

  </div>
</section>

<style>
  .reviews-section { background: var(--c-bg-2); }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .review-card {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .review-card:hover {
    border-color: rgba(0,102,204,0.25);
    box-shadow: 0 0 20px rgba(0,102,204,0.08);
  }

  .review-card__stars {
    display: flex;
    gap: 0.25rem;
    color: #F59E0B;
  }

  .review-card__text {
    font-size: 0.9rem;
    color: var(--c-ink-2);
    line-height: 1.7;
    flex: 1;
    font-style: normal;
  }

  .review-card__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--c-border);
  }

  .review-card__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--c-primary-light);
    border: 1px solid rgba(0,102,204,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--c-primary);
    flex-shrink: 0;
  }

  .review-card__author-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .review-card__name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-ink);
  }

  .review-card__role {
    font-size: 0.75rem;
    color: var(--c-muted);
  }

  .reviews-footer {
    display: flex;
    justify-content: center;
  }

  .reviews-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--c-muted);
  }
  .reviews-badge svg { color: #22c55e; }

  @media (max-width: 1024px) {
    .reviews-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }
</style>
