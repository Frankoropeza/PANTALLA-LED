---
import { url } from '../utils/url';
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-950 border-t border-gray-800 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href={url('/')} class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
            <span class="text-white font-heading font-bold text-sm">PL</span>
          </div>
          <span class="font-heading font-bold text-xl text-white">
            Pantalla<span class="text-primary">LED</span>
          </span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed max-w-sm">
          Especialistas en pantallas LED para publicidad exterior e interior.
          Venta, renta, instalación y mantenimiento en toda la República Mexicana.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Servicios</h3>
        <ul class="space-y-2">
          <li><a href={url('/servicios#instalacion')} class="text-gray-400 hover:text-white text-sm transition-colors">Instalación</a></li>
          <li><a href={url('/servicios#renta')} class="text-gray-400 hover:text-white text-sm transition-colors">Renta de Pantallas</a></li>
          <li><a href={url('/servicios#mantenimiento')} class="text-gray-400 hover:text-white text-sm transition-colors">Mantenimiento</a></li>
          <li><a href={url('/servicios#asesoria')} class="text-gray-400 hover:text-white text-sm transition-colors">Asesoría Técnica</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4">Contacto</h3>
        <ul class="space-y-2">
          <li class="flex items-center gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+525500000000" class="hover:text-white transition-colors">+52 55 0000 0000</a>
          </li>
          <li class="flex items-center gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:contacto@pantalla-led.com.mx" class="hover:text-white transition-colors">contacto@pantalla-led.com.mx</a>
          </li>
          <li class="flex items-center gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Ciudad de México, México</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm">
        © {currentYear} PantallaLED México. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-4">
        <a href={url('/privacidad')} class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Privacidad</a>
        <a href={url('/terminos')} class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Términos</a>
      </div>
    </div>
  </div>
</footer>
